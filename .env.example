# VayuDrishti environment. Copy to .env and fill real values. .env is gitignored.
# The pipeline validates these at startup with pydantic-settings and fails fast
# if a required one is missing or malformed. Owner of the authoritative schema:
# vayu-data (pipeline/vayu/settings.py). Keep names here in sync with it.
#
# Secrets are encrypted at rest after first run; add plaintext once, the app
# encrypts on next start. Never commit a filled .env. Placeholders below are
# deliberately fake and low-entropy so no scanner mistakes them for real keys.

# --- data.gov.in (CPCB live station snapshot) --------------------------------
# Register: https://data.gov.in/  ->  sign up  ->  My Account  ->  generate API key.
# Used with resource id 3b01bcb8-0b14-4abf-b6f2-c1bfd384ba69 (CPCB real-time AQI).
# The key goes in an X-header at request time; it MUST NEVER reach published JSON
# or lineage (data.gov.in normally puts it in the query string; we strip that).
DATA_GOV_IN_API_KEY=your_data_gov_in_api_key_here

# --- OpenAQ API v3 (live latest, alternate path) -----------------------------
# Register: https://explore.openaq.org/  ->  account  ->  API keys.
# Docs: https://docs.openaq.org/  (sent as the X-API-Key header).
OPENAQ_API_KEY=your_openaq_api_key_here

# --- Google Earth Engine (numeric satellite features + WorldPop for the Ledger) -
# Service account, headless, works in GitHub Actions. Team account is live:
# vayudrishti-ee@dmjone, key at ~/.config/vayudrishti/gee-sa.json, GEE_PROJECT=dmjone.
# To create your own:
# 1) https://console.cloud.google.com/  ->  create a service account, download JSON.
# 2) Enable the Earth Engine API and register the project at
#    https://code.earthengine.google.com/  (signup.earthengine.google.com).
# The GCP/Earth Engine project id the service account bills against.
GEE_PROJECT=your_gcp_project_id
# Provide the credentials ONE of two ways (path preferred locally, base64 in CI):
#   a) a filesystem path to the JSON key file, OR
GEE_SERVICE_ACCOUNT_JSON_PATH=./secrets/gee-service-account.json
#   b) the whole JSON key, base64-encoded (single line). Use this in CI: store it
#      as a GitHub Secret, the workflow decodes it to a temp file at runtime.
#      Encode with:  base64 -w0 gee-service-account.json
GEE_SERVICE_ACCOUNT_JSON=base64_encoded_gee_service_account_json_here

# --- NASA Earthdata token (LAADS/FIRMS archive backup path) -------------------
# Register: https://urs.earthdata.nasa.gov/  ->  log in  ->  Generate Token.
EARTHDATA_TOKEN=your_nasa_earthdata_bearer_token_here

# --- NASA FIRMS map key (VIIRS fires, optional; raises CSV rate limits) -------
# Register: https://firms.modaps.eosdis.nasa.gov/api/map_key/
# FIRMS bakes this key into the URL PATH, so it MUST NEVER reach published JSON.
FIRMS_MAP_KEY=your_firms_map_key_here

# --- NVIDIA Nemotron NIM (reasoning agents, evidence-cited action briefs) -----
# Register: https://build.nvidia.com/  ->  sign in  ->  generate an API key.
# Real keys start with nvapi- ; the brief stage is best-effort, never blocks publish.
# MUST NEVER reach published JSON or logs (the secret scan catches nvapi- keys).
NVIDIA_API_KEY=your_nvidia_nim_api_key_here

# --- Operational (non-secret) ------------------------------------------------
# Published web JSON + wards root (client fetches /data/*.json from here).
VAYU_WEB_DATA_DIR=web/public/data
# Feature-store and raw-download root (gitignored, ephemeral in CI).
VAYU_DATA_DIR=data
# Pipeline log level: error | warn | info | debug (structlog JSON to stdout).
LOG_LEVEL=info

# --- CI only (NOT read from .env in production) ------------------------------
# DEMO_FREEZE is a GitHub repository VARIABLE, not a secret. Set it to 1 in the
# repo settings (Aug 1-2) to skip the scheduled refresh job and pin the demo to
# a known-good deployment. Shown here only so local dry-runs can mimic it.
# DEMO_FREEZE=0
