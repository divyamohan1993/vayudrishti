{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vayudrishti.dmj.one/schemas/manifest.schema.json",
  "title": "VayuDrishti Manifest",
  "description": "Global entry index (spec 8). Drives the city picker, client-side geolocation (haversine vs centroid, coords never leave device), map init (bbox), and per-panel rendering (files present). cities is an ordered array. tier uses the hyphenated 'config-only' (config uses 'config_only'; mapped at publish).",
  "type": "object",
  "additionalProperties": false,
  "required": ["generated_at", "sat_numeric", "cities"],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "fixture": { "type": "boolean" },
    "sat_numeric": {
      "type": "boolean",
      "description": "True when the GEE numeric satellite feature path is active for this build (spec 3)."
    },
    "cities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "tier", "centroid", "bbox", "languages", "files"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z]+$" },
          "name": { "type": "string", "minLength": 1, "maxLength": 80 },
          "tier": { "type": "string", "enum": ["deep", "standard", "config-only"] },
          "centroid": {
            "type": "object",
            "additionalProperties": false,
            "required": ["lat", "lon"],
            "properties": {
              "lat": { "type": "number", "minimum": -90, "maximum": 90 },
              "lon": { "type": "number", "minimum": -180, "maximum": 180 }
            }
          },
          "bbox": {
            "type": "array",
            "description": "[west, south, east, north] in degrees.",
            "items": { "type": "number" },
            "minItems": 4,
            "maxItems": 4
          },
          "languages": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z]{2}$" },
            "minItems": 1,
            "maxItems": 4
          },
          "files": {
            "type": "object",
            "additionalProperties": false,
            "description": "Relative paths (from web/public/data/) for whatever this city publishes; consumers fetch only present keys.",
            "properties": {
              "nowcast": { "type": "string" },
              "forecast": { "type": "string" },
              "attribution": { "type": "string" },
              "enforcement": { "type": "string" },
              "advisories": { "type": "string" },
              "wards": { "type": "string" },
              "replay_index": { "type": "string" },
              "interventions": { "type": "string" },
              "ledger": { "type": "string" },
              "briefs": { "type": "string" }
            }
          },
          "fixture": { "type": "boolean" },
          "generated_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "agentlog": {
      "type": "string",
      "description": "Relative path to the global agentic run log (vayu-agents). Not per-city."
    }
  }
}
